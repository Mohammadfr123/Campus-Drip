# Supabase — get these from your Supabase project dashboard
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only key (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: restrict student signup to ALC email domain
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN=alc.mauritius.edu

# App URL (used for auth redirects in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (optional — for checkout in Step 7)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
